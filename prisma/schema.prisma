generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductionOrderStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProductionOrderPriority {
  LOW
  NORMAL
  HIGH
}

enum AssemblyOrderStatus {
  DRAFT
  IN_PROGRESS
  TESTING
  COMPLETED
  CANCELLED
}

enum AssemblyComponentStatus {
  RESERVED
  INSTALLED
  REPLACED
  REMOVED
}

/// V2 — ajoute ON_HOLD pour une reparation en attente (piece commandee,
/// attente client, panne intermittente non reproductible pour l'instant).
enum RepairOrderStatus {
  DRAFT
  IN_PROGRESS
  ON_HOLD
  TESTING
  COMPLETED
  CANCELLED
}

/// V2 — priorite atelier. Sert au tri du backlog.
enum RepairPriority {
  NORMAL
  HIGH
  URGENT
}

/// V2 — type d'intervention sur un composant (remplace RepairComponentAction).
/// REPLACED  = piece remplacee => 2 mouvements Stock (OUT neuf + IN ancien)
/// CHECKED   = piece controlee sur place, remise en etat => AUCUN mouvement
/// DIAGNOSED = piece en cours de diagnostic, decision differee => AUCUN mouvement
enum RepairInterventionKind {
  REPLACED
  CHECKED
  DIAGNOSED
}

/// V2 — etat intrinseque de la piece apres intervention (remplace
/// RepairComponentDisposition). Set pour toutes les lignes, pas seulement
/// pour les retraits.
///   OK        = piece validee, fonctionnelle (remise en stock USED si REPLACED)
///   DEFECTIVE = HS confirme, rebut
///   TO_CHECK  = suspicion, controle ulterieur necessaire
///   SUSPECT   = comportement anormal, peut lacher sous stress
enum RepairPartState {
  OK
  DEFECTIVE
  TO_CHECK
  SUSPECT
}

/// V2 — resultat final saisi a la cloture.
///   RESOLVED       = panne corrigee, borne repart
///   NOT_REPRODUCED = panne signalee mais non reproductible en atelier
///   BEYOND_REPAIR  = borne HS, a retirer du parc (declenchera souvent un demontage)
///   ESCALATED      = remonte fournisseur / R&D / SAV externe
enum RepairFinalResult {
  RESOLVED
  NOT_REPRODUCED
  BEYOND_REPAIR
  ESCALATED
}

/// Etat d'un demontage. Pas de TESTING (rien a tester, on demonte).
enum DisassemblyStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Ou va la piece qu'on vient de recuperer d'une borne demontee.
/// STOCK_NEW  = elle est parfaite, remise en stock neuf (rare mais possible
///              pour des consommables non ouverts)
/// STOCK_USED = elle est en bon etat, remise en stock occasion
/// TO_TEST    = SAV, a tester avant de decider
/// SCRAP      = rebut, on la trace en stock puis on la met a la poubelle
enum DisassemblyDisposition {
  STOCK_NEW
  STOCK_USED
  TO_TEST
  SCRAP
}

/// Etat d'un reconditionnement. Meme cycle qu'une reparation (avec TESTING)
/// car la borne repart en service, il faut la tester.
enum RefurbishmentStatus {
  DRAFT
  IN_PROGRESS
  TESTING
  COMPLETED
  CANCELLED
}

/// Meme semantique que RepairComponentAction — un reconditionnement fait
/// des retraits ET des installations.
enum RefurbishmentComponentAction {
  REMOVED
  INSTALLED
}

/// Sur reconditionnement, les pieces retirees sont typiquement gardees dans
/// l'atelier avec le meme classement que pour un demontage. On reutilise
/// donc le meme set de dispositions.
enum RefurbishmentDisposition {
  STOCK_NEW
  STOCK_USED
  TO_TEST
  SCRAP
}

/// One ProductionOrder = the decision to build N bornes of a given model.
/// Doesn't represent any specific borne yet — just the intent. When
/// validated, it spawns N AssemblyOrders.
model ProductionOrder {
  id              String                  @id @default(uuid())
  /// Free-text model identifier. Mirrors the `assembly_type.name` on the
  /// Stock side (e.g. "Borne Kalifun"). Not an FK — Factory doesn't own
  /// the Stock catalog.
  model           String
  quantity        Int
  status          ProductionOrderStatus   @default(DRAFT)
  priority        ProductionOrderPriority @default(NORMAL)
  /// Why this order exists ("saison ete", "commande client X", ...).
  reason          String?
  targetDate      DateTime?
  /// Keycloak sub of the creator (no FK to a local User table; we cache
  /// the name for display so the UI doesn't need to round-trip).
  createdById     String
  createdByName   String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  assemblyOrders  AssemblyOrder[]

  @@index([status])
  @@index([createdAt])
  @@map("production_orders")
}

/// One AssemblyOrder = one borne in the process of being built. A
/// ProductionOrder of `quantity=10` produces 10 AssemblyOrders.
model AssemblyOrder {
  id                  String              @id @default(uuid())
  productionOrderId   String
  productionOrder     ProductionOrder     @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  /// Internal Konitys numbering attributed at completion. Format defined
  /// by Bornes app (e.g. "S401" for a Spherik #401). NULL until completed.
  internalNumber      String?
  status              AssemblyOrderStatus @default(DRAFT)
  operatorId          String?
  operatorName        String?
  notes               String?
  /// JSON array of completed quality-check ids. Hardcoded in the frontend
  /// for the MVP; future versions will pull a configurable list per model.
  qualityChecks       Json?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  components          AssemblyComponent[]
  events              AssemblyOrderEvent[]

  @@index([productionOrderId])
  @@index([status])
  @@map("assembly_orders")
}

/// Append-only audit log for an AssemblyOrder. Drives the History panel
/// in the UI and gives traceability for compliance/warranty later.
///
/// `eventType` is a free string by design — we add new event kinds without
/// migrating an enum. Documented values used by the controllers:
///   - STARTED                 — operator clicked "Démarrer"
///   - STATUS_CHANGED          — payload: { from, to }
///   - COMPONENT_INSTALLED     — payload: { productRef, serialNumber? }
///   - COMPONENT_REMOVED       — payload: { productRef, serialNumber? }
///   - NOTES_UPDATED
///   - INTERNAL_NUMBER_SET     — payload: { value }
///   - QUALITY_CHECKED         — payload: { checkId }
///   - QUALITY_UNCHECKED       — payload: { checkId }
///   - COMPLETED               — payload: { internalNumber, movementsCreated }
///   - CANCELLED               — payload: { reason? }
model AssemblyOrderEvent {
  id                String         @id @default(uuid())
  assemblyOrderId   String
  assemblyOrder     AssemblyOrder  @relation(fields: [assemblyOrderId], references: [id], onDelete: Cascade)
  eventType         String
  payload           Json?
  actorId           String?
  actorName         String?
  createdAt         DateTime       @default(now())

  @@index([assemblyOrderId, createdAt])
  @@map("assembly_order_events")
}

/// Read-only local copy of Konitys users, fed by the `*.users.*` RabbitMQ
/// events via `services/refSync.ts`. NEVER write to this table from the
/// app — refSync is the only writer.
///
/// Columns are nullable on purpose (except `id`): the publisher may emit
/// partial rows or new columns, and we just upsert what we recognize.
///
/// Used by `OperatorAvatar` to render photos and full names for assembly
/// operators throughout the UI.
model UserRef {
  id         Int       @id
  email      String?
  nom        String?
  prenom     String?
  username   String?
  photo_nom  String?
  photo_url  String?
  actif      Boolean?
  created_at DateTime? @db.Timestamptz
  updated_at DateTime? @db.Timestamptz

  @@map("users_ref")
}

/// One component installed (or planned) on a specific assembly.
///
/// `productId` and `productReference` are NOT FKs — they live in Stock.
/// We cache the reference here so the Factory UI can render assembly
/// detail without round-tripping to Stock on every render.
///
/// When `status = INSTALLED`, the matching Stock movement OUT has already
/// been requested (via stockClient.createMovement).
model AssemblyComponent {
  id                String                  @id @default(uuid())
  assemblyOrderId   String
  assemblyOrder     AssemblyOrder           @relation(fields: [assemblyOrderId], references: [id], onDelete: Cascade)
  productId         String
  productReference  String
  /// Serial number for tracked products. Null for quantitative items.
  serialNumber      String?
  quantity          Int                     @default(1)
  status            AssemblyComponentStatus @default(RESERVED)
  installedAt       DateTime?
  removedAt         DateTime?
  createdAt         DateTime                @default(now())

  @@index([assemblyOrderId])
  @@index([productId])
  @@map("assembly_components")
}

/// Un RepairOrder = 1 borne physique en cours de reparation.
///
/// La borne est identifiee par `borneInternalNumber` (ex: "K001"). Elle
/// peut venir de Factory (assemblage Factory qu'on connait) ou directement
/// de Bornes (borne creee par l'app parc du collegue). `sourceApp` note
/// d'ou vient la reference — utile pour tracer et pour retrouver la
/// composition existante quand elle vient de Factory.
///
/// A la validation (COMPLETED), on publie `factory.repair_orders.completed`
/// pour que Bornes mette a jour l'etat de la borne dans le parc.
model RepairOrder {
  id                  String            @id @default(uuid())
  /// Numero interne de la borne. Format libre (ex "K001", "S401", "C100").
  /// Pas de FK — la borne n'est pas dans notre DB.
  borneInternalNumber String
  /// Origine du numero: "factory" (on l'a fabriquee ici) ou "bornes"
  /// (on l'a retrouvee dans l'app Bornes) ou "unknown" si non resolu.
  sourceApp           String            @default("unknown")
  status              RepairOrderStatus @default(DRAFT)
  /// V2 — priorite atelier (backlog).
  priority            RepairPriority    @default(NORMAL)
  /// Diagnostic libre saisi par l'operateur au demarrage.
  diagnosis           String?
  /// V2 — d'ou vient le diagnostic ("Cree manuellement", "Remonte du parc"...).
  /// Affiche dans le bandeau "Probleme signale". Null = valeur par defaut
  /// deduite de sourceApp cote UI.
  diagnosisSource     String?
  /// Ids/nom de l'operateur assigne (set au premier passage IN_PROGRESS).
  operatorId          String?
  operatorName        String?
  notes               String?
  qualityChecks       Json?
  /// V2 — motif de mise en attente (obligatoire pour transition ON_HOLD).
  onHoldReason        String?
  /// V2 — compte-rendu long saisi lors de la cloture.
  report              String?
  /// V2 — resultat final de la cloture (set en meme temps que report).
  finalResult         RepairFinalResult?
  startedAt           DateTime?
  completedAt         DateTime?
  createdById         String
  createdByName       String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  components  RepairComponent[]
  events      RepairOrderEvent[]
  attachments RepairAttachment[]

  @@index([borneInternalNumber])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("repair_orders")
}

/// V2 — Une ligne de la declaration d'intervention d'une reparation.
///
/// Contrairement a la V1 (une ligne = un mouvement REMOVED ou INSTALLED),
/// une ligne V2 = un couple (piece, action). L'action `kind` decide si on
/// declenche des mouvements Stock:
///   - REPLACED  => 2 mouvements Stock (OUT de la piece neuve + IN de l'ancienne)
///   - CHECKED   => aucun mouvement (piece resta sur la borne)
///   - DIAGNOSED => aucun mouvement (piece resta sur la borne, decision differee)
///
/// L'etat `partState` decrit l'etat intrinseque de la piece apres
/// intervention. Il est set pour toutes les lignes, meme CHECKED/DIAGNOSED,
/// pour qu'on puisse suivre l'evolution d'une piece dans le temps.
///
/// stockMovementIds contient les ids Stock (0, 1 ou 2) pour reconciliation.
model RepairComponent {
  id                String                 @id @default(uuid())
  repairOrderId     String
  repairOrder       RepairOrder            @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  kind              RepairInterventionKind
  productId         String
  productReference  String
  serialNumber      String?
  quantity          Int                    @default(1)
  partState         RepairPartState        @default(OK)
  /// Commentaire libre saisi par l'operateur sur cette ligne.
  comment           String?
  /// Ids Stock des mouvements crees pour cette ligne (JSON array de strings).
  /// Vide pour CHECKED/DIAGNOSED. 1 ou 2 ids pour REPLACED selon disponibilite Stock.
  stockMovementIds  Json?
  createdAt         DateTime               @default(now())

  @@index([repairOrderId])
  @@index([productId])
  @@map("repair_components")
}

/// V2 — Piece jointe attachee a une reparation (photo, PDF facture, etc.).
/// Stockage disque local dans uploads/repairs/. Une reparation peut avoir
/// plusieurs pieces jointes (rien ne limite).
model RepairAttachment {
  id              String       @id @default(uuid())
  repairOrderId   String
  repairOrder     RepairOrder  @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  filename        String
  url             String
  mimeType        String
  sizeBytes       Int
  uploadedById    String
  uploadedByName  String?
  createdAt       DateTime     @default(now())

  @@index([repairOrderId])
  @@map("repair_attachments")
}

/// Audit log append-only d'un RepairOrder. Meme pattern que
/// AssemblyOrderEvent — voir ce modele pour la doc detaillee.
model RepairOrderEvent {
  id             String       @id @default(uuid())
  repairOrderId  String
  repairOrder    RepairOrder  @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  eventType      String
  payload        Json?
  actorId        String?
  actorName      String?
  createdAt      DateTime     @default(now())

  @@index([repairOrderId, createdAt])
  @@map("repair_order_events")
}

/// Un Disassembly = 1 borne en fin de vie qu'on demonte.
///
/// Meme identification que RepairOrder (borneInternalNumber + sourceApp).
/// A la validation, on publie factory.disassemblies.completed pour que
/// Bornes archive la borne (statut = demontee, sortie du parc actif).
///
/// Difference vs Reparation:
/// - une seule "colonne" de composants (recuperation, pas d'installation)
/// - pas de statut TESTING (le test se fait plus tard, en SAV)
/// - pas de controles qualite
/// - le motif (reason) est obligatoire au demarrage
model Disassembly {
  id                  String            @id @default(uuid())
  borneInternalNumber String
  sourceApp           String            @default("unknown")
  status              DisassemblyStatus @default(DRAFT)
  /// V2 — priorite atelier (backlog). Utilise le meme enum que
  /// RepairOrder pour rester coherent metier.
  priority            RepairPriority    @default(NORMAL)
  /// Motif du demontage (fin de contrat, HS irreparable, cannibalisation...).
  reason              String?
  operatorId          String?
  operatorName        String?
  notes               String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdById         String
  createdByName       String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  components DisassemblyComponent[]
  events     DisassemblyEvent[]

  @@index([borneInternalNumber])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("disassemblies")
}

/// Une piece recuperee d'une borne demontee. Chaque ligne cree un mouvement
/// Stock IN au moment de sa creation. La condition du mouvement depend de
/// la disposition (NEW pour STOCK_NEW, USED pour tout le reste).
model DisassemblyComponent {
  id               String                 @id @default(uuid())
  disassemblyId    String
  disassembly      Disassembly            @relation(fields: [disassemblyId], references: [id], onDelete: Cascade)
  productId        String
  productReference String
  serialNumber     String?
  quantity         Int                    @default(1)
  disposition      DisassemblyDisposition
  stockMovementId  String?
  createdAt        DateTime               @default(now())

  @@index([disassemblyId])
  @@index([productId])
  @@map("disassembly_components")
}

/// Audit log append-only.
model DisassemblyEvent {
  id            String       @id @default(uuid())
  disassemblyId String
  disassembly   Disassembly  @relation(fields: [disassemblyId], references: [id], onDelete: Cascade)
  eventType     String
  payload       Json?
  actorId       String?
  actorName     String?
  createdAt     DateTime     @default(now())

  @@index([disassemblyId, createdAt])
  @@map("disassembly_events")
}

/// Un Refurbishment = 1 borne existante qu'on remet a neuf pour la relouer.
///
/// Ex: la borne K001 revient de chez un client apres 3 ans, on la refait
/// avec composants OK gardes + composants HS remplaces.
///
/// Difference vs RepairOrder (les 2 se ressemblent beaucoup):
/// - Reparation: intervention chez un client, borne reste chez lui
/// - Reconditionnement: borne revenue au depot, remise prete a re-louer
///
/// Difference vs Disassembly:
/// - Demontage: borne archivee (fin de vie)
/// - Reconditionnement: borne reintegree au parc dispo
///
/// borneInternalNumber inchange (voir Q1 = A). Publie
/// factory.refurbishments.completed a la validation — Bornes remet la borne
/// en statut "prete".
model Refurbishment {
  id                  String              @id @default(uuid())
  borneInternalNumber String
  sourceApp           String              @default("unknown")
  status              RefurbishmentStatus @default(DRAFT)
  /// V2 — priorite atelier (backlog). Meme enum que RepairOrder.
  priority            RepairPriority      @default(NORMAL)
  /// Motif du reconditionnement (fin de contrat, revision periodique, upgrade).
  reason              String?
  operatorId          String?
  operatorName        String?
  notes               String?
  qualityChecks       Json?
  startedAt           DateTime?
  completedAt         DateTime?
  createdById         String
  createdByName       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  components RefurbishmentComponent[]
  events     RefurbishmentEvent[]

  @@index([borneInternalNumber])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("refurbishments")
}

/// Un composant retire OU installe pendant un reconditionnement. Meme
/// structure que RepairComponent — la disposition n'est requise que pour
/// les REMOVED.
model RefurbishmentComponent {
  id               String                        @id @default(uuid())
  refurbishmentId  String
  refurbishment    Refurbishment                 @relation(fields: [refurbishmentId], references: [id], onDelete: Cascade)
  action           RefurbishmentComponentAction
  productId        String
  productReference String
  serialNumber     String?
  quantity         Int                           @default(1)
  disposition      RefurbishmentDisposition?
  stockMovementId  String?
  createdAt        DateTime                      @default(now())

  @@index([refurbishmentId])
  @@index([productId])
  @@map("refurbishment_components")
}

/// Audit log append-only.
model RefurbishmentEvent {
  id              String        @id @default(uuid())
  refurbishmentId String
  refurbishment   Refurbishment @relation(fields: [refurbishmentId], references: [id], onDelete: Cascade)
  eventType       String
  payload         Json?
  actorId         String?
  actorName       String?
  createdAt       DateTime      @default(now())

  @@index([refurbishmentId, createdAt])
  @@map("refurbishment_events")
}
