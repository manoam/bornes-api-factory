# PostgreSQL connection — create the DB first: `createdb bornes_factory_dev`
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bornes_factory_dev

# Express
PORT=3201
CORS_ORIGIN=http://localhost:5273

# Keycloak — same realm as Stock so users don't re-authenticate
KEYCLOAK_URL=https://keycloak.orkessi.com
KEYCLOAK_REALM=konitys
KEYCLOAK_CLIENT_ID=stock-management

# Konitys permissions — sent as header to gateway when calling requirePerm
APP_KEY=factory
GATEWAY_URL=https://plateform-gateway.orkessi.com
PLATEFORM_URL=https://plateform.orkessi.com

# Stock API — Factory reads products / stocks here. V1 = HTTP; V2 = RabbitMQ.
STOCK_API_URL=http://localhost:3001/api

# Bornes API — Factory matches its produced bornes against the parc.
# Read-only call to /ws/bornes/all with a static ws_token in query.
# Both vars required to enable the matching; otherwise produced-bornes
# page shows "non configuré".
BORNES_API_URL=https://bornesdev-api.orkessi.com
BORNES_WS_TOKEN=

# RabbitMQ — shared platform.events bus. If RABBITMQ_URL is empty Factory
# starts anyway, just without publishing. Use the same instance as Stock so
# Bornes / Stock can consume factory.assembly_orders.* events.
RABBITMQ_URL=
RABBITMQ_HTTP_URL=
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=platform.events
APP_NAME=factory
